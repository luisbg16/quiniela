# ─── Base de datos PostgreSQL ────────────────────────────────
# Con Supabase (reemplazá [TU-PASSWORD] con tu contraseña del proyecto):
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.xxhuejwrpoeyjigqcnlq.supabase.co:5432/postgres
#
# Lo encontrás en: Supabase Dashboard → Settings → Database → Connection string → URI

# ─── JWT ─────────────────────────────────────────────────────
# Generá un string aleatorio seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────
# URL del frontend (Vite dev server)
FRONTEND_URL=http://localhost:5173

# ─── Webservice de afiliados (Laravel Chorotega) ─────────────────────────────
# GET ${AFILIADOS_WS_URL}/{dni}   (formato DNI: xxxx-xxxx-xxxxx)
# Responde: { status_code: 200 } si es afiliado | { status_code: 404 } si no
# Si no se configura, la verificación automática queda deshabilitada (no bloquea el registro).
AFILIADOS_WS_URL=https://afiliacion.chorotega.hn/validar-dni
