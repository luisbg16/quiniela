# ─── Base de datos PostgreSQL ────────────────────────────────
# Con Supabase (reemplazá [TU-PASSWORD] con tu contraseña del proyecto):
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.xxhuejwrpoeyjigqcnlq.supabase.co:5432/postgres
#
# Lo encontrás en: Supabase Dashboard → Settings → Database → Connection string → URI

# ─── JWT ─────────────────────────────────────────────────────
# Generá un string aleatorio seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────
# URL del frontend (Vite dev server)
FRONTEND_URL=http://localhost:5173

# ─── Webservice de afiliados ──────────────────────────────
# URL del endpoint que verifica si un DNI es afiliado activo.
# GET ${AFILIADOS_WS_URL}?dni=0801199012345
# Debe responder JSON con al menos uno de: { esAfiliado, activo, afiliado, estado }
# Si no se configura, la verificacion automatica queda deshabilitada (no bloquea el registro).
AFILIADOS_WS_URL=
# Token Bearer de autenticacion (dejar vacio si el WS no requiere auth)
AFILIADOS_WS_TOKEN=
